# KW_AutoTrading 환경 변수 템플릿
# 이 파일을 복사하여 .env 로 저장하고, 실제 키를 입력하세요.
# ⚠️  .env 파일은 절대 Git에 커밋하지 마세요! (.gitignore 처리됨)
#
# 간편 설정: python setup_keys.py 실행

# ── AT_Sig (자동매매 엔진) ──────────────────────────────────
AT_REAL_APP_KEY=여기에_AT_실거래_APP_KEY_입력
AT_REAL_APP_SECRET=여기에_AT_실거래_APP_SECRET_입력
AT_PAPER_APP_KEY=여기에_AT_모의_APP_KEY_입력
AT_PAPER_APP_SECRET=여기에_AT_모의_APP_SECRET_입력

# ── Analyzer_Sig (선도주 분석 엔진) ────────────────────────
# AT_Sig와 동일 계좌 사용 시 위 키를 그대로 복사해도 됩니다
ANAL_REAL_APP_KEY=여기에_ANALYZER_실거래_APP_KEY_입력
ANAL_REAL_APP_SECRET=여기에_ANALYZER_실거래_APP_SECRET_입력
ANAL_PAPER_APP_KEY=여기에_ANALYZER_모의_APP_KEY_입력
ANAL_PAPER_APP_SECRET=여기에_ANALYZER_모의_APP_SECRET_입력

# ── 텔레그램 알림 ───────────────────────────────────────────
# Bot Token: BotFather에서 /newbot 명령으로 발급
# Chat ID:   @userinfobot 에 /start 전송 후 확인
TELEGRAM_TOKEN=여기에_TELEGRAM_BOT_TOKEN_입력
TELEGRAM_CHAT_ID=여기에_TELEGRAM_CHAT_ID_입력

# ── 공용 (shared/api.py) ────────────────────────────────────
KW_REAL_APP_KEY=여기에_SHARED_실거래_APP_KEY_입력
KW_REAL_APP_SECRET=여기에_SHARED_실거래_APP_SECRET_입력
